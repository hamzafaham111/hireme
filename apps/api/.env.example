PORT=4000
# User, password, and database must exist in PostgreSQL (see README).
# If the password contains @ # : / etc., URL-encode them (e.g. @ → %40).
DATABASE_URL=postgresql://hireme:hireme@localhost:5432/hireme?schema=public
JWT_SECRET=change-me-in-production-use-long-random-string
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Public URL of this API (no /api/v1). Used in blog image upload responses so markdown img src works from the dashboard and Next.js.
PUBLIC_BASE_URL=http://localhost:4000
# Optional override; defaults to ./uploads under the API process cwd
# UPLOAD_DIR=
